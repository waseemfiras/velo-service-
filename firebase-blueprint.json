{
  "entities": {
    "GlobalStats": {
      "title": "GlobalStats",
      "description": "Global visitor statistics.",
      "type": "object",
      "properties": {
        "total_visitors": { "type": "number" },
        "last_visit": { "type": "object" }
      }
    },
    "GlobalConfig": {
      "title": "GlobalConfig",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "ai_chat_enabled": { "type": "boolean" },
        "maintenance_mode": { "type": "boolean" },
        "maintenance_message": { "type": "string" }
      }
    },
    "ServiceRequest": {
      "title": "ServiceRequest",
      "description": "Custom project service request with tracking details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "projectTitle": { "type": "string" },
        "selectedService": { "type": "string" },
        "estimatedBudget": { "type": "string" },
        "preferredTimeline": { "type": "string" },
        "country": { "type": "string" },
        "projectDescription": { "type": "string" },
        "referenceLinks": { "type": "string" },
        "additionalNotes": { "type": "string" },
        "attachmentName": { "type": "string" },
        "attachmentType": { "type": "string" },
        "attachmentData": { "type": "string" },
        "preferredContactMethod": { "type": "string" },
        "status": { "type": "string" },
        "latestUpdate": { "type": "string" },
        "assignedTeam": { "type": "string" },
        "estimatedDelivery": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "fullName", "email", "projectTitle", "selectedService", "estimatedBudget", "preferredTimeline", "projectDescription", "preferredContactMethod", "status"]
    },
    "UserChats": {
      "title": "UserChats",
      "description": "Stored chat sessions for a specific user.",
      "type": "object",
      "properties": {
        "sessions": { "type": "array" },
        "currentSessionId": { "type": "string" }
      },
      "required": ["sessions", "currentSessionId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Premium user profile card and settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "joinDate": { "type": "string" },
        "location": { "type": "string" },
        "plan": { "type": "string" },
        "avatar": { "type": "string" },
        "credits_total": { "type": "number" },
        "credits_used": { "type": "number" },
        "credits_remaining": { "type": "number" },
        "language": { "type": "string" },
        "theme": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "plan", "credits_remaining"]
    },
    "Project": {
      "title": "Project",
      "description": "Cloud saved project configurations, design history, and prompts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "style": { "type": "string" },
        "color": { "type": "string" },
        "createdDate": { "type": "string" },
        "updatedDate": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "settings": { "type": "object" },
        "pages": { "type": "array" },
        "components": { "type": "array" },
        "userId": { "type": "string" },
        "createdBy": { "type": "string" },
        "aiHistory": { "type": "array" }
      },
      "required": ["id", "name", "type", "style", "userId", "createdDate", "updatedDate", "status"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User interface language, theme, and dev-preferences.",
      "type": "object",
      "properties": {
        "theme": { "type": "string" },
        "language": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["theme", "language"]
    }
  },
  "firestore": {
    "analytics/{docId}": {
      "schema": "GlobalStats",
      "description": "Analytics tracking"
    },
    "settings/{docId}": {
      "schema": "GlobalConfig",
      "description": "Settings configuration"
    },
    "service_requests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "Collection of all submitted service requests"
    },
    "user_chats/{userId}": {
      "schema": "UserChats",
      "description": "User's stored chat sessions"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile records and billing plans"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "User saved cloud projects"
    },
    "settings_sync/{userId}": {
      "schema": "UserSettings",
      "description": "User settings synchronization across devices"
    }
  }
}
